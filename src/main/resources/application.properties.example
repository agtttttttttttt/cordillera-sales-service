spring.application.name=backend

spring.jpa.hibernate.ddl-auto=update
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQL8Dialect
spring.datasource.url=jdbc:mysql://mysql-cdy2203:3306/mydatabase
spring.datasource.username=myuser
spring.datasource.password=password
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

server.port=8180

# AWS - reemplazar con tus credenciales
aws.region=us-east-1
aws.accessKeyId=TU_ACCESS_KEY
aws.secretAccessKey=TU_SECRET_KEY
aws.sessionToken=TU_SESSION_TOKEN
aws.sqs.queue.url=https://sqs.us-east-1.amazonaws.com/TU_CUENTA/solicitudes-queue
